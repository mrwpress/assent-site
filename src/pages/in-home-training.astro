---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="In Home Training" description="Custom in-home dog training tailored to your specific needs in central Colorado.">
  <section class="page-hero">
    <div class="container">
      <h1>In Home Dog Training</h1>
      <p>Custom tailored training in the comfort of your own home.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background-color: var(--color-bg-dark);
    color: var(--color-white);
    padding: 80px 0;
    text-align: center;
  }

  .page-hero h1 {
    font-size: 2.2rem;
    margin-bottom: 16px;
  }

  .page-hero p {
    font-size: 1.1rem;
    opacity: 0.8;
  }
</style>
