---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Medical Service Dog Program" description="Medical service dog team training program in central Colorado.">
  <section class="page-hero">
    <div class="container">
      <h1>Medical Service Dog Team Training</h1>
      <p>Helping dogs and handlers work together as a strong, confident team.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background-color: var(--color-bg-dark);
    color: var(--color-white);
    padding: 80px 0;
    text-align: center;
  }

  .page-hero h1 {
    font-size: 2.2rem;
    margin-bottom: 16px;
  }

  .page-hero p {
    font-size: 1.1rem;
    opacity: 0.8;
  }
</style>
