---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Legal Services" description="Legal services and information from Assent Canine Training.">
  <section class="page-hero">
    <div class="container">
      <h1>Legal Services</h1>
      <p>Expert guidance on canine-related legal matters.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background-color: var(--color-bg-dark);
    color: var(--color-white);
    padding: 80px 0;
    text-align: center;
  }

  .page-hero h1 {
    font-size: 2.2rem;
    margin-bottom: 16px;
  }

  .page-hero p {
    font-size: 1.1rem;
    opacity: 0.8;
  }
</style>
