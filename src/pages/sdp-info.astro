---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ADA Information and Resources" description="ADA information and resources for service dog handlers.">
  <section class="page-hero">
    <div class="container">
      <h1>ADA Information and Resources</h1>
      <p>Know your rights as a service dog handler.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background-color: var(--color-bg-dark);
    color: var(--color-white);
    padding: 80px 0;
    text-align: center;
  }

  .page-hero h1 {
    font-size: 2.2rem;
    margin-bottom: 16px;
  }

  .page-hero p {
    font-size: 1.1rem;
    opacity: 0.8;
  }
</style>
