---
import PreHeader from '../components/PreHeader.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Professional dog training in central Colorado. Service dogs, therapy dogs, family dogs, puppies, and AKC certified training.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Host+Grotesk:wght@300;400;500;600;700&family=Open+Sans:wght@300;400;600;700;800&family=Playfair+Display:wght@400;500;600;700&family=Urbanist:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title} | Assent Canine Training</title>
  </head>
  <body>
    <PreHeader />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
