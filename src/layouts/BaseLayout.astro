---
import PreHeader from '../components/PreHeader.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  schema?: Record<string, unknown>;
}

const defaultDescription = 'Professional dog training in central Colorado. Service dogs, therapy dogs, family dogs, puppies, and AKC certified training.';
const { title, description = defaultDescription, ogImage = '/images/og-default.svg', schema } = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
const fullTitle = `${title} | Assent Canine Training`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Assent Canine Training',
  description: defaultDescription,
  url: 'https://assentcaninetraining.com',
  telephone: ['720-377-5797', '303-641-7421'],
  email: 'customerservice@assentcaninetraining.com',
  areaServed: {
    '@type': 'State',
    name: 'Colorado',
  },
  serviceType: [
    'Dog Training',
    'Service Dog Training',
    'Therapy Dog Training',
    'AKC Certified Training',
    'In Home Dog Training',
    'Disabled Canine Training',
  ],
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Assent Canine Training" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.href} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Host+Grotesk:wght@300;400;500;600;700&family=Open+Sans:wght@300;400;600;700;800&family=Playfair+Display:wght@400;500;600;700&family=Urbanist:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{fullTitle}</title>

    <!-- LocalBusiness Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Per-page Schema (e.g. FAQPage) -->
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </head>
  <body>
    <PreHeader />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
