---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us" description="Contact Assent Canine Training for professional dog training in Colorado.">
  <section class="page-hero">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Get in touch with our team today.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background-color: var(--color-bg-dark);
    color: var(--color-white);
    padding: 80px 0;
    text-align: center;
  }

  .page-hero h1 {
    font-size: 2.2rem;
    margin-bottom: 16px;
  }

  .page-hero p {
    font-size: 1.1rem;
    opacity: 0.8;
  }
</style>
