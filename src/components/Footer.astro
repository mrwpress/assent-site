---
const companyLinks = [
  { href: '/', label: 'Home' },
  { href: '/about-us', label: 'About Us' },
  { href: '/contact', label: 'Contact Us' },
];

const socialLinks = [
  { href: 'https://www.instagram.com/', label: 'Instagram' },
  { href: 'https://x.com/', label: 'Twitter' },
  { href: 'https://www.facebook.com/', label: 'Facebook' },
];

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <h5 class="footer-title">Our Company</h5>
        <ul class="footer-links">
          {companyLinks.map(link => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col footer-center">
        <h4 class="footer-phone">
          Got questions, give us a call.<br />
          <a href="tel:7203775797">(720) 377-5797</a> / <a href="tel:3036417421">(303) 641-7421</a>
        </h4>
        <a href="mailto:customerservice@assentcaninetraining.com" class="footer-email">
          customerservice@assentcaninetraining.com
        </a>
        <p class="copyright">
          &copy; Copyright - Assent Canine Training 2010 - {currentYear} All Rights Reserved.
        </p>
      </div>

      <div class="footer-col">
        <h5 class="footer-title">Social</h5>
        <ul class="footer-links">
          {socialLinks.map(link => (
            <li><a href={link.href} target="_blank" rel="noopener noreferrer" class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-dark);
    color: var(--color-white);
    padding: 60px 0 40px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: 40px;
    align-items: start;
  }

  .footer-title {
    font-family: var(--font-ui);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 20px;
    color: var(--color-accent);
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-link {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-white);
    opacity: 0.8;
    transition: opacity 0.2s, color 0.2s;
  }

  .footer-link:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  .footer-center {
    text-align: center;
  }

  .footer-phone {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 500;
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .footer-phone a {
    color: var(--color-accent);
  }

  .footer-email {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-accent);
    display: inline-block;
    margin-bottom: 24px;
  }

  .copyright {
    font-size: 0.8rem;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-links {
      align-items: center;
    }
  }
</style>
